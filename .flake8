[flake8]
max-line-length = 120
exclude =
    .venv,
    .vercel_tmp_env,
    node_modules,
    frontend/node_modules,
    __pycache__,
    .git,
    build,
    dist,
    *.egg-info,
    uv,
    build_packages
extend-ignore =
    E501,
    W291,W292,W293,W391,
    E127,E128,E202,
    E225,E231,
    E301,E302,E303,E304,E305,E306,
    E401,E402,
    E702,
    E711,E712,
    E731,E741,
    W191,W503,W504,W605,
    F401,F403,F405,F541,F811,F821,F841
