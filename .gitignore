# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Distribution / packaging
build/
dist/
*.egg-info/

# Logs and runtime files
*.log
*.sqlite3
test_phase6_out*.txt
memory_backup.jsonl

# Editor directories and files
.vscode/
.idea/
*.swp

# OS generated files
.DS_Store
Thumbs.db

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject version info into it.
*.manifest
*.spec