#!/usr/bin/env bash
# Wrapper to ensure `uv lock` uses the Vercel-created venv path when executed during builds.
# If called with `uv lock` and no --python provided, append the builder venv path.

set -euo pipefail

REAL_UV="/usr/local/bin/uv"

if [ "$#" -ge 1 ] && [ "$1" = "lock" ]; then
  skip_python=false
  for a in "$@"; do
    if [ "$a" = "--python" ]; then
      skip_python=true
      break
    fi
  done

  if ! $skip_python; then
    # prefer the builder venv path; fall back to project .venv if present
    if [ -x ".vercel/python/.venv/bin/python" ]; then
      PYPATH=".vercel/python/.venv/bin/python"
    elif [ -x ".venv/bin/python" ]; then
      PYPATH=".venv/bin/python"
    else
      PYPATH=".vercel/python/.venv/bin/python"
    fi
    exec "$REAL_UV" lock --python "$PYPATH" "${@:2}"
  fi
fi

# Default: delegate to the real uv binary
exec "$REAL_UV" "$@"
