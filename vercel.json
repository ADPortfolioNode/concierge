{
  "version": 2,
  "build": {
    "outputDirectory": "frontend/dist",
    "env": { "VITE_API_URL": "<self.server>" }
  },
  "routes": [
    { "src": "^/api/_health$", "dest": "/main.py" },
    { "src": "^/health$", "dest": "/main.py" },
    { "src": "^/api/(.*)$", "dest": "/main.py" },
    { "src": "^/__files$", "dest": "/main.py" },
    { "src": "^/openapi.json$", "dest": "/main.py" },
    { "src": "^/docs$", "dest": "/main.py" },
    { "src": "^/redoc$", "dest": "/main.py" },
    { "src": "^/ask$", "dest": "/main.py" },
    { "src": "^/assets/(.*)$", "dest": "/main.py" },
    { "src": "^/index.html$", "dest": "/main.py" },
    { "src": "^/(.*)$", "dest": "/main.py" }
  ]
}