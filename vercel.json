{
  "version": 2,
  "builds": [
    { "src": "main.py", "use": "@vercel/python" },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm install && npm run build"
      }
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "<self.server>",
      "VITE_API_URL_LOCAL": "http://localhost:8001",
      "VITE_API_URL_DOCKER": "http://app:8001",
      "VITE_API_URL_STAGING": "<self.server>",
      "VITE_API_URL_PRODUCTION": "<self.server>",
      "VITE_API_URL_SET": "",
      "VITE_API_URL_AUTO_DETECT": "true"
    }
  },
  "env": {
    "VITE_API_URL_LOCAL": "http://localhost:8001",
    "VITE_API_URL_DOCKER": "http://app:8000",
    "VITE_API_URL_STAGING": "<self.server>",
    "VITE_API_URL_PRODUCTION": "<self.server>",
    "VITE_API_URL_SET": "",
    "VITE_API_URL_AUTO_DETECT": "true"
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/api/(.*)$", "dest": "/main.py" },
    { "src": "^/.*$", "dest": "/main.py" }
  ]
}
