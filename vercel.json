{
  "version": 2,
  "builds": [
    { "src": "main.py", "use": "@vercel/python" },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm install && npm run build"
      }
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "<self.server>",
      "VITE_API_URL_LOCAL": "http://localhost:8000",
      "VITE_API_URL_DOCKER": "http://app:8000",
      "VITE_API_URL_STAGING": "<self.server>",
      "VITE_API_URL_PRODUCTION": "<self.server>",
      "VITE_API_URL_SET": "",
      "VITE_API_URL_AUTO_DETECT": "true"
    }
  },
  "env": {
    "VITE_API_URL_LOCAL": "http://localhost:8000",
    "VITE_API_URL_DOCKER": "http://app:8000",
    "VITE_API_URL_STAGING": "<self.server>",
    "VITE_API_URL_PRODUCTION": "<self.server>",
    "VITE_API_URL_SET": "",
    "VITE_API_URL_AUTO_DETECT": "true"
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/assets/(.*)$", "dest": "/frontend/dist/assets/$1" },
    { "src": "^/(logo-optimized\\.svg|logo\\.svg|logo-dark\\.svg|logo-mono\\.svg|logo_README\\.md|task-layout-1\\.svg|task-layout-2\\.svg|task-layout-3\\.svg|workflow-collaboration\\.svg|workflow-insights\\.svg|workflow-design\\.svg|favicon\\.ico)$", "dest": "/frontend/dist/$1" },
    { "src": "^/api/(.*)$", "dest": "/main.py" },
    { "src": "^/.*$", "dest": "/main.py" }
  ]
}
