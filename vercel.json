{
  "version": 2,
  "builds": [
    { "src": "main.py", "use": "@vercel/python" },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm install && npm run build"
      }
    }
  ],
  "routes": [
    { "src": "^/api/_health$", "dest": "/main.py" },
    { "src": "^/api/(.*)$", "dest": "/main.py" },
    { "src": "^/__files$", "dest": "/main.py" },
    { "src": "^/assets/(.*)$", "dest": "/main.py" },
    { "src": "^/index.html$", "dest": "/main.py" },
    { "src": "^/(.*)$", "dest": "/main.py" }
  ]
}
